const N: subtype { x: int | x > 5 };
type R = struct { x: int; y: int }; 

node N() returns (o: map<int, int>; o2: map<[int, int], int>; o3: map<[[int, int], int], int>; o4: map<[int, int], [int, int]>; o5: map<int, [int, int]>; o6: map<R, int>) 
var l: int; var l6: int;
var l2: int; var l7: int;
var l3: int; var l8: int;
var l4: [int, int]; var l9: [int, int];
var l5: [int, int]; var l10: [int, int];
var l11: int;
let
    o = map[]@<int, int>[3 := 5; 4 := 6];
    o2 = map[]@<[int, int], int>['(3, 4) := 5; '(6, 7) := 8];
    o3 = map[]@<[[int, int], int], int>['('(3, 4), 5) := 5; '('(6, 7), 8) := 9];
    o4 = map[]@<[int, int], [int, int]>['(3, 4) := '(5, 6); '(7, 8) := '(9, 10)];
    o5 = map[]@<int, [int, int]>[3:= '(5, 6); 4:= '(7, 8)];
    o6 = map[]@<R, int>[R {x = 3; y = 4} := 5];

    l = o[3]; l6 = o[4];
    l2 = o2['(3, 4)]; l7 = o2['(6, 7)];
    l3 = o3['('(3, 4), 5)]; l8 = o3['('(6, 7), 8)];
    l4 = o4['(3, 4)]; l9 = o4['(7, 8)];
    l5 = o5[3]; l10 = o5[4];
    l11 = o6[R {x = 3; y = 4}];

    check l = 5;
    check l6 = 6;
    check (l2 = 5);
    check l7 = 8;
    check l3 = 5;
    check l8 = 9;
    check l4 = '(5, 6);
    check l9 = '(9, 10);
    check l5 = '(5, 6);
    check l10 = '(7, 8);
    check l11 = 5;
    check 3 in o; 
    check 4 in o;
    check '(3, 4) in o2;
    check '(6, 7) in o2;
    check '('(3, 4), 5) in o3;
    check '('(6, 7), 8) in o3;
    check '(3, 4) in o4;
    check '(7, 8) in o4;
    check 3 in o5;
    check 4 in o5;
    check R {x = 3; y = 4} in o6;
    check (forall (i: int) i <> 3 and i <> 4 => not (i in o));
    check (forall (i: [int, int]) i <> '(3, 4) and i <> '(6, 7) => not (i in o2)); 
    check (forall (i: [[int, int], int]) i <> '('(3, 4), 5) and i <> '('(6, 7), 8) => not (i in o3)); 
    check (forall (i: [int, int]) i <> '(3, 4) and i <> '(7, 8) => not (i in o4));
    check (forall (i: int) i <> 3 and i <> 4 => not (i in o5));
    check (forall (i: R) i <> (R {x = 3; y = 4}) => not (i in o6));
tel


 
