-- Quantifier in specification
node slide (const n:int; s: int) returns(ok: bool^n);
var A: int^n;
var pre_A: int^n;
let
  pre_A[i] = -1 -> pre A[i]; 
  A[i] = if i = 0 then s otherwise pre_A[i-1];
  ok[i] = A[i] = -1 or A[i] = s or (false -> pre ok[i]);
  --%PROPERTY forall (i: int) 0 <= i and i < n ==> ok[i];
tel
