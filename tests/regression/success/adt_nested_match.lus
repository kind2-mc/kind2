-- Nested ADT pattern matching: Inner is a field type of Outer.
datatype Inner = A | B (int);
datatype Outer = Wrap (Inner) | Empty;

node main(o: Outer) returns (ok: bool);
var val: int;
let
  val = match o with
    | Wrap(A) : 0
    | Wrap(B(n)) : n
    | Empty : -1
  end;
  ok = o = Empty => val = -1;
  --%PROPERTY ok;
tel
