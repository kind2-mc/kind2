const len : int = 3;

node array_pre( 
    ins : real;
) returns (
    prevs1, prevs2 : real^len;
)
var
  zeros : real^len;
  pre_prevs1 : real^len;
  pre_prevs2 : real^len;
let
  -- Workaround for typechecker bug: (0.0^len -> pre prevs1)[i] fails.
  zeros = 0.0^len;

  pre_prevs1 = zeros -> pre prevs1;
  pre_prevs2[i] = 0.0 -> pre prevs2[i];

  -- These two definitions should be equivalent:
  prevs1[i] = if i = 0 then ins otherwise pre_prevs1[i - 1];
  prevs2[i] = if i = 0 then ins otherwise pre_prevs2[i - 1];
  --%PROPERTY prevs1[0] = prevs2[0];
  --%PROPERTY prevs1[1] = prevs2[1];
  --%PROPERTY prevs1[2] = prevs2[2];
tel


