
function imported f(x: int) returns (y: int);
con
  assume "A1" x >= 0;
noc

node N(x: int) returns (y: int);
let
  when x = 0 then
    y = f(x);
  else
    when x < 0 then
      y = f(-x) - 1;
    else
      y = f(x) + 1;
    end
  end
  check "P1" x = 0 ==> y = f(x);
  check "P2" x < 0 ==> y = f(-x) - 1;
  check "P3" x > 0 ==> y = f(x) + 1;
tel
