node test(x: int) returns (y1, y2, y3: int; p1, p2: bool);
let 
  p1 = (y1 = 5) or (y1 = 6);
  p2 = (counter(0) < 5 => (y2 = 10));
  --%PROPERTY p1;
  --%PROPERTY p2;
  
  (* Non-constant guard *)
  if (counter(0) < 5)
  then 
    y1 = 5;
    y2 = 10;
  else 
    y1 = 6;
    y2 = any@<int>;
  fi
  y3 = any@<int>;
tel

node counter(init: int) returns (y: int);
let
   y = init -> (pre y + 1);
tel;
