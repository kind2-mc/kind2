type Nat = subtype { x: int | x >= 0 };
type Pos = subtype { x: int | x >= 1 };

type PosPair = [Pos, Pos]; 
type NatPair = [Nat, Nat]; 

type R2 = struct { x: Pos; y: Pos }; 
type R = struct { x: Pos; y: R2 };
  
node N(inp1:   map<Pos, int>; inp2: map<int, Pos>; inp3: map<Pos, Pos>; inp4: map<PosPair, PosPair>) 
returns (out1: map<Nat, int>; out2: map<int, Nat>; out3: map<Pos, Pos>; out4: map<PosPair, NatPair>; out5: R) 
let
    out1 = inp1;
    out2 = inp2;
    out3 = inp3;
    out4 = inp4;
    out5 = R { x = 1; y = R2 { x = 2; y = 3; }; };
tel
