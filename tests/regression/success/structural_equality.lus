const N: subrange [1, *] of int;

node N  (sc_x: int; x1: bool^N; x2: [int, int]; x3: [int, int]^N; x4: [map<[int, int], bool>, map<[int, int], bool>]; 
         x5: map<int, bool>; x6, y6: set<int>) 
returns (sc_y: int; y1: bool^N; y2: [int, int]; y3: [int, int]^N; y4: [map<[int, int], bool>, map<[int, int], bool>];
         y5: map<int, bool>;)
(*@contract
  assume exists (i: int) (i in x6) and not (i in y6);
*)
let
  y1 = x1; 
  sc_y = sc_x;
  y2 = x2;
  y3 = x3;
  y4 = x4;
  y5 = x5;

  check sc_x = sc_y;
  check exists (bound: int) bound = bound + 0;
  check forall (i: subrange [0, N-1] of int) x1[i] = y1[i];
  check x2 = y2;
  check x1 = y1;
  check forall (i: subrange [0, N-1] of int) x3[i] = y3[i];
  check x4 = y4;
  check x5 = y5;
  check not (x6 = y6);
  check x6 <> y6;
tel

type K = [int, int];
type V = [int, int];
node M (m1, m2: map<K, V>) returns ()
(*@contract 
  assume forall (i: K) (i in m1) = (i in m2) and (i in m1 => m1[i] = m2[i]);
*)
let
  check m1 = m2;
tel
