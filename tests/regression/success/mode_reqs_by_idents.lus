node abs (i: int) returns (out: int) ;
let
  out = if i < 0 then -i else i ;
  (*%PROPERTY out >= 0 ; *)
  /*!PROPERTY : if i < 0 then (out = -i) else (out = i) ; */
tel

node has_been_true(i: bool) returns (out: bool) ;

/* @contract

  mode false_so_far (
    require not (i or (false -> pre out)) ;
    ensure not out ;
  ) ;

  mode i_true (
    require i ;
    ensure out ;
  ) ;

  mode always_true (
    require not ::false_so_far ;
    require i -> pre out ;
    ensure out ;
  ) ;
*/
let
  out = i or (false -> pre out) ;
tel


node my_node (i: int) returns (out: int) ;

(*@contract

  const bound = 10 ;
  var i_bounded: bool = abs(i) < bound ;

  assume i_bounded ;
  guarantee out >= - bound ;

  mode i_neg (
    require i < 0 ;
    ensure out = i ;
  ) ;

  mode i_pos (
    require not ::i_neg ;
    ensure out >= 0 ;
    ensure true -> (
      (pre has_been_true(i > 0)) => out > i
    ) ;
  ) ;
*)
var mem: int ;
let
  mem = abs(i) + (0 -> pre mem) ;
  out = if i < 0 then i else mem ;

  (* Old style still works. *)
  --%PROPERTY out - i >= 0 ;

  (* Doing the same thing using different annotations. *)
  (*!MAIN: true ; *)
  (*%MAIN ; *)
  --%MAIN ;
  --!MAIN: true ;
tel