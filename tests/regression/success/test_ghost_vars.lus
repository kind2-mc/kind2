node top (i:bool) returns (out:bool);
(*@contract
  gvar v2 : bool = false -> pre v1;
  gvar v1 : bool = false;
  guarantee true;
*)
let
  out = i;
tel

node top2 (i:bool) returns (out:bool);
(*@contract
 mode m1 (
 require true -> pre(v2) = pre(v2););
 gvar v2 : bool = false -> pre v1;
 gvar v1 : bool = true -> v2;
 guarantee true;
*)
let
  out = i;
tel
