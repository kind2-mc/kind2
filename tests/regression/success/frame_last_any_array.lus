node count1 (m: bool) returns (A: int^3);
let
  frame (A)
    A[i] = any { v: int | v >= 0 };
  let
    when m then
      A[i] = last A[i] + 1;
    end
  tel
  check "nonneg1" A[0] >= 0;
tel

node count2 (m: bool) returns (B: int^2^2);
let
  frame (B)
    B[i][j] = any { v: int | v >= 0 };
  let
    when m then
      B[i][j] = last B[i][j] + 1;
    end
  tel
  check "nonneg2" B[0][1] >= 0;
tel

-- A deterministic array initialization referenced through 'last' exercises the
-- same array-recursive last-definition (independent of 'any'); a plain
-- 'last_A = 0 -> pre A' would be rejected as an arrow type mismatch (int vs
-- int^3).
node count3 (m: bool) returns (A: int^3);
let
  frame (A)
    A[i] = 0;
  let
    when m then
      A[i] = last A[i] + 1;
    end
  tel
  check "nonneg3" A[0] >= 0;
tel
