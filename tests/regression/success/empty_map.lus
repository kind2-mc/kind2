node N() returns (o: map<int, int>) 
var l1: map<[int, int], int>;
var l2: map<[int, int], [real, real]>;
let
    o = map[]@<int, int>;
    l1 = map[]@<[int, int], int>;
    l2 = map[]@<[int, int], [real, real]>;
    check not (3 in o);
    check not ('(3, 4) in l1);
    check not ('(3, 4) in l2);
tel
