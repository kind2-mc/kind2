datatype Msg = Atomic (int) | Enc (Msg, Msg) | Pair (Msg, Msg);
datatype Option<T> = None | Some (T);

function dec(m, k: Msg) returns (out: Option<Msg>)
let
  out = match m with 
  | Enc (m2, k2) : if k = k2 then Some (m2) else None@<Msg>
  | _ : None@<Msg> 
  end;
tel

node main(plain: Msg; key: Msg) returns (ok: bool; cipher, decrypted: Msg);
let
  cipher = Enc(plain, key);
  decrypted = match dec(cipher, key) with 
  | None : choose@<Msg>
  | Some (plain) : plain
  end;
  ok = decrypted = plain;
  check ok;
tel
