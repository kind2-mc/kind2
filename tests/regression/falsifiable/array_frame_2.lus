node N(i, j: int^4) returns (A3, A4: int^4);
let
  frame (A3)
    A3[i] = 0;
  let
    A3 = pre i;
  tel
  check true -> A3[0] = 0;

  frame (A4)
    A4 = i;
  let
    A4[i] = pre 0;
  tel
  check true -> A4[0] = 0;
  check true -> A4[0] = 0;
tel

node M(i, j: int) returns (A5: int^4);
let
  frame (A5)
    A5[i] = j + i; 
  let
    A5[j] = pre (i + j);
    -- A5[fresh] = (j + fresh) -> pre (i + fresh)
  tel
  check true -> A5[0] = 0;
tel