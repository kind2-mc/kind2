datatype Flag = F | T;

node two(m: Flag) returns (c1, c2: int);
let
  c1 =
    match m with
    | T : 1 -> pre c2 + 1
    | F : 0 -> pre c2 + 1
    end
    ;

  c2 = 10 -> if not (pre c2 = 99) then 99 else 22;
tel

node main() returns (c1, c2: int);
var d: Flag;
let
  d = T ->  if pre d = T then F else T;
  c1, c2 = two(d);
  check "P1" not (c1 = 23 and c2 = 22);
tel
