node saturation (i: int) returns (out: int) ;
(*@contract
  assume i >= 0 ;
  guarantee out >= 0 ;
  guarantee out <= 42 ;
  mode pass_through (
    require i < 42 ;
    ensure out = i ;
  ) ;
  mode saturate (
    require i >= 42 ;
    ensure out = 42 ;
  ) ;
*)
let out = if i >= 42 then 42 else i ; tel

node top (i: int) returns (out: int) ;
(*@contract
  assume i >= 0 ;
  guarantee out <= 42 ;
*)
var tmp: int ;
let
  tmp = i - 1 ;
  out = saturation(tmp) ;
tel