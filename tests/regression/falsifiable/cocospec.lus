contract bla_spec(i: real ; ignored: bool) returns (out: real) ;
let
  assume i <> 0.0 ;
  assume not ignored ;
  guarantee out = i - 1.0 ;

  mode mode_1 (
    require i > 1.0 ;
    ensure out > 7.0 ;
    ensure out > 0.0 ;
    ensure out > 5.0 ;
  ) ;

  mode mode_2 (
    require i <= 1.0 ;
    ensure out < 7.0 ;
    ensure out < 0.0 ;
    ensure out < 5.0 ;
    ensure out < -3.0 ;
  ) ;
tel

contract bli_spec (i: real ; ignored: bool) returns (out: real) ;
let
  guarantee out = i - 1.0 ;
  import bla_spec (i, ignored) returns (out) ;
tel

node bla(i: real ; ignored: bool) returns (out: real) ;
(*@contract
  import bla_spec (i, ignored) returns (out) ;
*)
let
  out = if ignored then i - 1.0 else i - 1.0 ;
tel

node bli(i: real ; ignored: bool) returns (out: real) ;
(*@contract
  import bli_spec (i, ignored) returns (out) ;
  import bla_spec (i, ignored) returns (out) ;
*)
let
  out = bla(i, ignored) ;
tel