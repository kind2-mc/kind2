node one (i: two) returns (out: two) ;
(*@contract
  import blah (i) returns (out) ;
*)
let
  out = two(0.0 -> pre i) ;
tel

node two (i: two) returns (out: two) ;
let
  out = 0.0 -> pre i ;
tel

contract blah (i: two) returns (out: real) ;
let
  import blih (i) returns (out) ;
  assume i >= 0.0 ;
  guarantee out >= 0.0 ;
tel

contract blih (i: two) returns (out: real) ;
let
  import blah (i) returns (out) ;
  assume i >= 0.0 ;
  guarantee out >= 0.0 ;
tel

type one = { blah: two } ;

type two = real ;

