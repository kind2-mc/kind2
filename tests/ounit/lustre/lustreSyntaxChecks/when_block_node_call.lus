function imported f(x: int) returns (y: int);
con
  assume "A1" x >= 0;
noc

node G(x: int) returns (y: int);
let
  y = 1;
tel

node N(x: int) returns (y: int);
let
  when x >= 0 then 
    y = G(x);
  else 
    y = f(x) - 1;
  end
  check "P1" x = 0 ==> y = f(x);
  check "P2" x < 0 ==> y = f(x) - 1;
tel