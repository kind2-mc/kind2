-- Illegal import of a stateful contract in a function contract.

node imported N( i: int ) returns ( out: int );

contract blah_spec (i: int) returns (out: int) ;
let
  guarantee out = N(i);
tel

function blah ( i: int ) returns ( out: int ) ;
(*@contract
  import blah_spec (i) returns (out) ;
*)
let
  out = i ;
tel
