const MAX_SIZE: subrange[1,*] of int;

type Index = subtype { i: int | -1 <= i and i < MAX_SIZE };

type Stack<T> = struct {
  items: T^MAX_SIZE;
  top_pos: Index;
};

type Bad<T> = struct {
  val: int;
};

node N(s1:Stack<bool>) returns (s2:Stack<int>; b: Bad<bool>;);
let
  s2 = Stack {  
    items = 2^MAX_SIZE;
    top_pos = 3;
  };

  b = Bad { 
    val = 3; 
  }; 
