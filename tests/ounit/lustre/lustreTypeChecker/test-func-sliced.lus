function imported sincos(i: real) returns (sin: real; cos: real);
(*@contract
  const max = 1.0;
  const pi = 3.14;
  const tau = 2.0 * pi;
  var min:real = - max;
  assume i <= 0.0 or i >= 0.0;
  guarantee min <= sin and sin <= max;

  mode pos (
    require 0.0 <= i and i <= tau;
    ensure sin >= 0.0;
  );

  mode neg (
    require - tau <= i and i <= 0.0;
    ensure sin <= 0.0;
  );
*)

node X (i: real) returns (OK: bool);
var inn: real ;
let
  inn = i ; 
  OK =
    exp(0.0 -> inn, 1.0 -> inn) > 0.0 or
    sincos(0.0 -> inn + pre inn) + sincos(0.0 -> inn + pre inn) = (0.0, 0.0);
tel;

node id (i: real) returns (out: int);
(*@contract
  const max = 1.0;
  const pi = 3.14;
  const tau = 2.0 * pi;
  var min:real = - max;
  assume - tau <= i ;
*)
var inn: real ; ok: bool ;
let
  out = (int i);
  inn = i ;
  ok = X(inn) ;
  --%PROPERTY ok ;
  --%MAIN ;
tel;

function imported exp (x, y: real) returns (out: real);
(* @contract
   guarantee out >= id(out);
   guarantee out <= sin(out);
*)

function sin(i: real) returns (out: int);
let
   out = (int i);
tel