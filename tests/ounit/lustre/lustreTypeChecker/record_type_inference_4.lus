const MAX_SIZE: subrange[1,*] of int;

type Index = subtype { i: int | -1 <= i and i < MAX_SIZE };

type Stack<T> = struct {
  items: T^MAX_SIZE;
  val: T;
  top_pos: Index;
};

node N(s1:Stack<bool>) returns (s2:Stack<int>;);
let
  s2 = Stack {  
    items = 3^MAX_SIZE;
    val = false; 
    top_pos = 3;
  };
