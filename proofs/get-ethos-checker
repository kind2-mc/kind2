#!/usr/bin/env bash

set -e -o pipefail

# A script to download and build the ethos checker. Based on
# https://github.com/cvc5/cvc5/blob/main/contrib/get-ethos-checker

# utility function to download a file
function download {
  if [ -x "$(command -v wget)" ]; then
    wget -c -O "$2" "$1"
  elif [ -x "$(command -v curl)" ]; then
    curl -L "$1" >"$2"
  else
    echo "Can't figure out how to download from web.  Please install wget or curl." >&2
    exit 1
  fi
}

SCRIPT_DIR="$(dirname "$(realpath "$0")")"
KIND_DIR=`realpath $SCRIPT_DIR/../`

pushd $KIND_DIR/proofs

BASE_DIR=`pwd`
# Clean up directories from a previous run
rm -rf $BASE_DIR/bin $BASE_DIR/tmp $BASE_DIR/signatures/cpc
mkdir -p $BASE_DIR/bin
mkdir -p $BASE_DIR/tmp

##### EO
EO_DIR="$BASE_DIR/tmp/ethos-checker"
mkdir -p $EO_DIR

# download and unpack ethos
ETHOS_VERSION="7059fc50a12d1efa6c075163d445f34edceab1ae"
download "https://github.com/cvc5/ethos/archive/$ETHOS_VERSION.tar.gz" $BASE_DIR/tmp/ethos.tgz
tar --strip 1 -xzf $BASE_DIR/tmp/ethos.tgz -C $EO_DIR

# build and install Ethos
pushd $EO_DIR
mkdir -p build && cd build
cmake -DCMAKE_INSTALL_PREFIX="$BASE_DIR" ..
make -j$(nproc)
cp ./src/ethos $BASE_DIR/bin/ethos
popd

##### signatures

# The CPC signatures live in the main cvc5 repository
version="cvc5-1.3.1"

# download the CPC signatures
pushd $BASE_DIR/tmp
git clone --no-checkout --branch $version --depth 1 https://github.com/cvc5/cvc5.git
cd cvc5
git sparse-checkout init --cone
git sparse-checkout set proofs/eo/cpc/
git checkout $version
cp -r proofs/eo/cpc/ $BASE_DIR/signatures/
popd

# install scripts

# Script for checking Eunoia proofs generated by Kind 2
cat << EOF > $BASE_DIR/bin/ethos_check.sh
#!/usr/bin/env bash

cat \$@ | grep WARNING
CHECK=\$(cat \$@ | grep "step proof_safe")
[ -z "\$CHECK" ] && echo "; WARNING: Safety proof missing"

$BASE_DIR/bin/ethos \\
  --include=$BASE_DIR/signatures/cpc/Cpc.eo \\
  --include=$BASE_DIR/signatures/cpc/expert/CpcExpert.eo \\
  --include=$BASE_DIR/signatures/Safety.eo \\
  \$@
EOF
chmod +x $BASE_DIR/bin/ethos_check.sh

echo ""
echo "========== How to use Ethos =========="
echo "Check a generated proof:"
echo "  $BASE_DIR/bin/ethos_check.sh <proof file>"
echo
